{
  "name": "transformr-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "engines": {
    "node": "20.19.4"
  },
  "scripts": {
    "start": "expo start --dev-client",
    "start:clear": "expo start --dev-client --clear",
    "start:tunnel": "expo start --tunnel -c",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "node -e \"require('fs').mkdirSync('.expo/types',{recursive:true});require('fs').writeFileSync('.expo/types/router.d.ts','// generated stub\\n')\" && tsc --noEmit",
    "test": "jest --logHeapUsage",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "doctor": "npx expo-doctor",
    "prebuild": "npx expo prebuild",
    "prebuild:clean": "npx expo prebuild --clean"
  },
  "dependencies": {
    "@expo/vector-icons": "14.1.0",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/netinfo": "11.4.1",
    "@stripe/stripe-react-native": "0.45.0",
    "@supabase/supabase-js": "^2.83.0",
    "@tanstack/react-query": "5.90.10",
    "date-fns": "^3.6.0",
    "expo": "~53.0.23",
    "expo-application": "~6.1.5",
    "expo-auth-session": "~6.2.1",
    "expo-av": "~15.1.0",
    "expo-build-properties": "~0.14.0",
    "expo-calendar": "~14.1.4",
    "expo-camera": "~16.1.0",
    "expo-constants": "~17.1.0",
    "expo-crypto": "~14.1.5",
    "expo-device": "~7.1.0",
    "expo-file-system": "~18.1.0",
    "expo-font": "~13.3.0",
    "expo-haptics": "~14.1.0",
    "expo-image": "~2.4.1",
    "expo-image-picker": "~16.1.0",
    "expo-linear-gradient": "~14.1.5",
    "expo-linking": "~7.1.0",
    "expo-local-authentication": "~16.0.5",
    "expo-location": "~18.1.0",
    "expo-notifications": "~0.31.0",
    "expo-router": "~5.1.10",
    "expo-secure-store": "~14.2.0",
    "expo-sharing": "~13.1.5",
    "expo-speech": "~13.1.7",
    "expo-splash-screen": "~0.30.0",
    "expo-status-bar": "~2.2.0",
    "expo-task-manager": "~12.0.6",
    "expo-updates": "~0.28.0",
    "expo-web-browser": "~14.2.0",
    "getenv": "^2.0.0",
    "lodash": "^4.17.21",
    "lottie-react-native": "7.2.2",
    "react": "19.0.0",
    "react-native": "0.79.6",
    "react-native-draggable-flatlist": "^4.0.0",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-mmkv": "^3.0.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "15.11.2",
    "react-native-url-polyfill": "^2.0.0",
    "uuid": "9.0.1",
    "victory-native": "^41.20.2",
    "zustand": "4.5.7"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@expo/metro-runtime": "~3.2.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/lodash": "^4.17.0",
    "@types/react": "~19.0.10",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "~13.0.0",
    "eslint": "8.57.1",
    "eslint-config-expo": "~9.2.0",
    "eslint-config-prettier": "10.1.8",
    "jest": "^29.7.0",
    "jest-expo": "~53.0.10",
    "patch-package": "^8.0.1",
    "prettier": "3.6.2",
    "schema-utils": "^4.3.3",
    "typescript": "~5.8.3"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "expo-av",
          "schema-utils",
          "uuid"
        ],
        "listUnknownPackages": false
      }
    },
    "install": {
      "exclude": [
        "@expo/metro-runtime",
        "expo-task-manager",
        "typescript"
      ]
    }
  }
}
