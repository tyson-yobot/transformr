# EAS Build ignore file
# Same as .gitignore plus additional EAS-specific excludes

# --- Standard gitignore entries ---
node_modules/
.expo/
dist/
npm-debug.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*
web-build/

# --- EAS-specific excludes ---

# Original uncompressed video files (duplicates of the optimized versions)
assets/videos/originals/

# App store marketing assets not needed for build
app-store-assets/

# Local Android build cache (not the source — keep android/ itself for EAS)
android/app/build/
android/.gradle/
