# =============================================================================
# TRANSFORMR Mobile App — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your real values.
# All EXPO_PUBLIC_* vars are bundled into the app — do NOT put secrets here.
# =============================================================================

# Supabase (get from: Supabase Dashboard > Settings > API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google Sign-In — Web Client ID (OAuth 2.0 > Web client in Google Cloud Console)
# Must match the client ID registered in Supabase Auth > Google provider
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Stripe (get from: Stripe Dashboard > Developers > API Keys)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key-here

# Spotify (get from: developer.spotify.com > Dashboard > Your App)
EXPO_PUBLIC_SPOTIFY_CLIENT_ID=your-spotify-client-id-here

# OpenFoodFacts (free public API — no key needed)
EXPO_PUBLIC_OPEN_FOOD_FACTS_API=https://world.openfoodfacts.org/api/v2

# Expo Application Services (get from: expo.dev > Your Project > Overview)
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id-here

# OpenWeatherMap (get from: openweathermap.org/api — free tier)
# Used for weather-aware AI recommendations (hydration, training timing, sleep)
EXPO_PUBLIC_OPENWEATHER_API_KEY=your-openweather-api-key-here

# App Environment (development | preview | production)
EXPO_PUBLIC_APP_ENV=development
