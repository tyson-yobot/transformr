{
  "expo": {
    "name": "TRANSFORMR",
    "slug": "transformr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "transformr",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.automateai.transformr",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "TRANSFORMR uses the camera for meal photos, barcode scanning, progress photos, and exercise form checks.",
        "NSPhotoLibraryUsageDescription": "TRANSFORMR uses your photo library for progress photos and vision board images.",
        "NSMicrophoneUsageDescription": "TRANSFORMR uses the microphone for voice commands and workout narration.",
        "NSLocationWhenInUseUsageDescription": "TRANSFORMR uses your location for gym geofence triggers.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "TRANSFORMR monitors location to auto-start workouts when you arrive at the gym.",
        "NSFaceIDUsageDescription": "TRANSFORMR uses Face ID to protect your personal data.",
        "NFCReaderUsageDescription": "TRANSFORMR uses NFC to trigger automations from physical tags.",
        "NSMotionUsageDescription": "TRANSFORMR uses motion data for activity tracking."
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.nfc.readersession.formats": ["TAG"],
        "com.apple.developer.siri": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "package": "com.automateai.transformr",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "RECORD_AUDIO",
        "VIBRATE",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "NFC",
        "INTERNET",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-image-picker",
      "expo-notifications",
      "expo-location",
      "expo-local-authentication",
      "expo-secure-store",
      "expo-av",
      "expo-file-system",
      ["expo-font", {
        "fonts": []
      }],
      ["expo-splash-screen", {
        "backgroundColor": "#0F172A",
        "image": "./assets/images/splash.png",
        "imageWidth": 200
      }]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      },
      "supabaseUrl": "YOUR_SUPABASE_URL",
      "supabaseAnonKey": "YOUR_SUPABASE_ANON_KEY"
    }
  }
}
