{
  "expo": {
    "name": "TRANSFORMR",
    "slug": "transformr",
    "version": "1.0.0",
    "orientation": "portrait",
    "updates": {
      "enabled": false,
      "url": "https://u.expo.dev/placeholder"
    },
    "runtimeVersion": "1.0.0",
    "icon": "./assets/icons/transformr-icon.png",
    "scheme": "com.automateai.transformr",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#0C0A15"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.automateai.transformr",
      "icon": "./assets/icons/transformr-icon.png",
      "buildNumber": "1",
      "jsEngine": "hermes",
      "infoPlist": {
        "NSCameraUsageDescription": "TRANSFORMR uses the camera for meal photos, barcode scanning, progress photos, and exercise form checks.",
        "NSPhotoLibraryUsageDescription": "TRANSFORMR uses your photo library for progress photos and vision board images.",
        "NSMicrophoneUsageDescription": "TRANSFORMR uses the microphone for voice commands and workout narration.",
        "NSLocationWhenInUseUsageDescription": "TRANSFORMR uses your location for gym geofence triggers.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "TRANSFORMR monitors location to auto-start workouts when you arrive at the gym.",
        "NSFaceIDUsageDescription": "TRANSFORMR uses Face ID to protect your personal data.",
        "NFCReaderUsageDescription": "TRANSFORMR uses NFC to trigger automations from physical tags.",
        "NSMotionUsageDescription": "TRANSFORMR uses motion data for activity tracking.",
        "NSCalendarsUsageDescription": "TRANSFORMR uses your calendar to schedule workouts and reminders.",
        "NSRemindersUsageDescription": "TRANSFORMR uses reminders to help you stay on track with your goals."
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.nfc.readersession.formats": [
          "TAG"
        ],
        "com.apple.developer.siri": true
      }
    },
    "android": {
      "jsEngine": "hermes",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/transformr-icon.png",
        "backgroundColor": "transparent"
      },
      "package": "com.automateai.transformr",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.VIBRATE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.NFC",
        "android.permission.INTERNET",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.711780683734-0ampvv9dj8fi1ogv1f6hqbfpk970oah6"
        }
      ],
      "expo-camera",
      "expo-image-picker",
      "expo-notifications",
      "expo-location",
      "expo-local-authentication",
      "expo-secure-store",
      "expo-file-system",
      [
        "expo-font",
        {
          "fonts": []
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0C0A15"
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.automateai.transformr",
          "enableGooglePay": true
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supabaseUrl": "https://horqwbfsqqmzdbbafvov.supabase.co",
      "supabaseAnonKey": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImhvcnF3YmZzcXFtemRiYmFmdm92Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU2MDczOTMsImV4cCI6MjA5MTE4MzM5M30.GAY9ystuTThmXkSmrjSTKuSbZkpcWgkEaYKxSPhMBtM",
      "privacyPolicyUrl": "https://transformr.app/privacy",
      "termsOfServiceUrl": "https://transformr.app/terms",
      "eas": {
        "projectId": "02da9bda-cd59-455a-a5c6-665595a7bf5e"
      }
    },
    "owner": "tysonlerfald"
  }
}
