{
  "name": "transformr",
  "version": "1.0.0",
  "private": true,
  "description": "TRANSFORMR - AI-Powered Life Transformation Platform",
  "author": "Automate AI LLC",
  "license": "UNLICENSED",
  "engines": {
    "node": "20.19.4"
  },
  "workspaces": {
    "packages": [
      "apps/mobile"
    ],
    "nohoist": [
      "**/react-native",
      "**/react-native/**",
      "**/expo",
      "**/expo/**",
      "**/@expo/**",
      "**/@shopify/**",
      "**/victory-native",
      "**/victory-native/**",
      "**/lottie-react-native",
      "**/lottie-react-native/**",
      "**/@react-native/**",
      "**/@react-native-community/**",
      "**/react-native-*",
      "**/react-native-*/**"
    ]
  },
  "scripts": {
    "mobile": "cd apps/mobile && npx expo start",
    "mobile:ios": "cd apps/mobile && npx expo run:ios",
    "mobile:android": "cd apps/mobile && npx expo run:android",
    "lint": "cd apps/mobile && npx eslint .",
    "typecheck": "cd apps/mobile && npx tsc --noEmit",
    "test": "cd apps/mobile && npx jest",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:migrate": "supabase db push",
    "supabase:reset": "supabase db reset",
    "supabase:seed": "supabase db seed",
    "supabase:functions:deploy": "supabase functions deploy",
    "build:preview": "cd apps/mobile && eas build --profile preview",
    "build:production": "cd apps/mobile && eas build --profile production",
    "submit:ios": "cd apps/mobile && eas submit --platform ios",
    "submit:android": "cd apps/mobile && eas submit --platform android",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-keywords": "^5.1.0",
    "expo": "~53.0.27",
    "expo-calendar": "^55.0.14",
    "normalize-path": "^3.0.0",
    "picomatch": "^4.0.4",
    "react": "19.0.0",
    "react-native": "0.79.6",
    "react-native-nfc-manager": "^3.17.2",
    "schema-utils": "^4.3.3",
    "typescript": "~5.6.3"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "eslint": "8.57.1",
    "eslint-config-prettier": "10.1.8",
    "pg": "^8.20.0",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0"
  },
  "overrides": {
    "es-abstract": "1.24.0"
  }
}
