{
  "name": "transformr",
  "version": "1.0.0",
  "private": true,
  "description": "TRANSFORMR - AI-Powered Life Transformation Platform",
  "author": "Automate AI LLC",
  "license": "UNLICENSED",
  "engines": {
    "node": "20.19.4"
  },
  "workspaces": [
    "apps/mobile"
  ],
  "scripts": {
    "mobile": "cd apps/mobile && npx expo start",
    "mobile:ios": "cd apps/mobile && npx expo run:ios",
    "mobile:android": "cd apps/mobile && npx expo run:android",
    "lint": "cd apps/mobile && npx eslint .",
    "typecheck": "cd apps/mobile && npx tsc --noEmit",
    "test": "cd apps/mobile && npx jest",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:migrate": "supabase db push",
    "supabase:reset": "supabase db reset",
    "supabase:seed": "supabase db seed",
    "supabase:functions:deploy": "supabase functions deploy",
    "build:preview": "cd apps/mobile && eas build --profile preview",
    "build:production": "cd apps/mobile && eas build --profile production",
    "submit:ios": "cd apps/mobile && eas submit --platform ios",
    "submit:android": "cd apps/mobile && eas submit --platform android"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-keywords": "^5.1.0",
    "normalize-path": "^3.0.0",
    "picomatch": "^4.0.4",
    "schema-utils": "^4.3.3",
    "typescript": "~5.6.3"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  }
}
