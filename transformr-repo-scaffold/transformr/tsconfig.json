{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": ["apps/mobile/*"],
      "@components/*": ["apps/mobile/components/*"],
      "@services/*": ["apps/mobile/services/*"],
      "@stores/*": ["apps/mobile/stores/*"],
      "@hooks/*": ["apps/mobile/hooks/*"],
      "@utils/*": ["apps/mobile/utils/*"],
      "@types/*": ["apps/mobile/types/*"],
      "@theme/*": ["apps/mobile/theme/*"],
      "@assets/*": ["apps/mobile/assets/*"]
    }
  },
  "include": ["apps/mobile/**/*.ts", "apps/mobile/**/*.tsx"],
  "exclude": ["node_modules", "**/*.test.ts", "**/*.test.tsx"]
}
