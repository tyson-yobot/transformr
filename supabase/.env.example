# =============================================================================
# TRANSFORMR — Supabase Edge Functions Environment Variables
# =============================================================================
# These are set via Supabase Dashboard > Edge Functions > Secrets
# or via `supabase secrets set` CLI command.
# Copy this file to .env for local development with `supabase functions serve`.
# =============================================================================

# Supabase (auto-provided in production, needed for local dev)
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anthropic Claude API (for AI Edge Functions)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Stripe (required for billing pipeline)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
STRIPE_CONNECT_CLIENT_ID=ca_your-connect-client-id

# QuickBooks (required for accounting sync)
QB_CLIENT_ID=your-qb-client-id
QB_CLIENT_SECRET=your-qb-client-secret
QB_REFRESH_TOKEN=your-qb-refresh-token
QB_COMPANY_ID=your-qb-company-id
QB_ENVIRONMENT=sandbox

# Referral System Thresholds (optional — defaults in code)
REFERRAL_MIN_MONTHS=2
REFERRAL_MIN_ACTIVITY=3
SQUAD_MIN_MONTHS=3
CREATOR_MIN_REFERRALS=10
CREATOR_PAYOUT_THRESHOLD=50
